<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>505 — Server Error | Please try again</title>
  <!-- Bootstrap 5 CSS + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <!-- Shared theme stylesheet -->
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ----- 500 PAGE ENHANCEMENTS — uses global CSS variables from style.css ----- */
    body {
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
      background: linear-gradient(145deg, var(--bg-light) 0%, var(--gray-bg) 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    /* modern error card: subtle border, glass-like elevation */
    .error-card {
      background: rgba(255, 255, 255, 0.96);
      border-radius: 2rem;
      box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.08), 0 8px 18px rgba(0, 0, 0, 0.02);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      border: 1px solid var(--border-light);
    }

    .error-card:hover {
      box-shadow: 0 30px 50px -15px rgba(0, 0, 0, 0.12);
    }

    /* 500 massive typography — brand-blue gradient */
    .error-code {
      font-size: 8rem;
      font-weight: 800;
      line-height: 1;
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.03em;
    }

    /* subtle floating animation for server icon */
    @keyframes floatSoft {
      0%   { transform: translateY(0px); }
      50%  { transform: translateY(-6px); }
      100% { transform: translateY(0px); }
    }

    .server-icon {
      font-size: 4.2rem;
      color: var(--primary-light);
      display: inline-block;
      animation: floatSoft 3s ease-in-out infinite;
      filter: drop-shadow(0 8px 12px rgba(75, 122, 156, 0.15));
    }

    /* primary action button — brand blue */
    .btn-accent {
      background-color: var(--primary);
      border: none;
      padding: 0.75rem 1.8rem;
      font-weight: 500;
      border-radius: 60px;
      transition: all 0.2s ease;
      box-shadow: var(--shadow-sm);
    }

    .btn-accent:hover {
      background-color: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(42, 78, 119, 0.25);
    }

    .btn-outline-support {
      border-radius: 60px;
      padding: 0.65rem 1.6rem;
      font-weight: 500;
      border: 1px solid var(--border-focus);
      color: var(--text-muted);
      transition: all 0.2s;
    }

    .btn-outline-support:hover {
      background-color: var(--bg-light);
      border-color: var(--text-light);
      transform: translateY(-1px);
    }

    /* helper text line */
    .help-text {
      color: var(--text-muted);
      font-size: 0.95rem;
      border-top: 1px solid var(--border-light);
      padding-top: 1.2rem;
    }

    @media (max-width: 576px) {
      .error-code { font-size: 5.5rem; }
      .server-icon { font-size: 3rem; }
      .error-card { padding: 2rem 1.5rem !important; }
      .btn-accent, .btn-outline-support {
        width: 100%;
        text-align: center;
        margin-bottom: 0.5rem;
      }
      .button-group {
        flex-direction: column;
        gap: 0.75rem !important;
      }
    }

    @media (min-width: 768px) {
      .error-code { font-size: 10rem; }
    }

    /* smooth focus ring for accessibility */
    .btn:focus-visible {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }

    a { text-decoration: none; }
  </style>
</head>
<body>

  <div class="container py-4">
    <div class="row justify-content-center align-items-center min-vh-100">
      <div class="col-12 col-md-10 col-lg-8 col-xl-7">
        <!-- main error card with modern layout & spacing -->
        <div class="error-card p-4 p-md-5 text-center">
          
          <!-- icon + error code row: responsive alignment -->
          <div class="mb-4">
            <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap">
              <i class="bi bi-hdd-stack server-icon"></i>
              <span class="error-code">505</span>
            </div>
          </div>

          <!-- friendly human readable message -->
          <h1 class="h3 fw-semibold text-dark mb-2">Unexpected server condition</h1>
          <p class="lead fs-5 text-secondary mb-3">
            Oops! Something went wrong on our end.
          </p>
          
          <!-- helpful explanation for users (reassuring and professional) -->
          <div class="bg-light bg-opacity-50 rounded-3 p-3 mx-auto mb-4" style="max-width: 460px;">
            <p class="mb-0 small text-secondary">
              <i class="bi bi-info-circle-fill me-1" style="font-size: 0.85rem;"></i> 
              Our engineers have been notified. This issue is temporary — please try again in a few minutes.
            </p>
          </div>

          <!-- optional enhancement: brief list of actions the user can take -->
          <div class="row g-2 mb-4 text-start mx-1">
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2 text-secondary-emphasis bg-white rounded-3 p-2 px-3 border">
                <i class="bi bi-arrow-repeat text-primary"></i>
                <span class="small">Refresh the page after a moment</span>
              </div>
            </div>
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2 text-secondary-emphasis bg-white rounded-3 p-2 px-3 border">
                <i class="bi bi-house-door text-primary"></i>
                <span class="small">Navigate to our homepage</span>
              </div>
            </div>
          </div>

          <!-- action buttons group: return to homepage + go back + contact support -->
          <div class="button-group d-flex flex-wrap justify-content-center gap-3 mt-2 mb-4">
            <a href="/" class="btn btn-accent text-white px-4 py-2">
              <i class="bi bi-house-fill me-2"></i>Return to Homepage
            </a>
            <button onclick="window.history.back();" class="btn btn-outline-secondary btn-outline-support">
              <i class="bi bi-arrow-left me-2"></i>Go Back
            </button>
            <a href="#support-modal" data-bs-toggle="modal" class="btn btn-outline-support">
              <i class="bi bi-chat-dots me-1"></i>Contact Support
            </a>
          </div>

          <!-- additional helpful message with contact hints & status reference (optional) -->
          <div class="help-text mt-2 d-flex justify-content-center gap-3 flex-wrap small">
            <span><i class="bi bi-database-slash me-1"></i> Error reference: 505 HTTP</span>
            <span><i class="bi bi-envelope me-1"></i> <a href="#" class="text-decoration-none text-secondary-hover" data-bs-toggle="modal" data-bs-target="#support-modal">support@example.com</a></span>
            <span><i class="bi bi-twitter-x me-1"></i> <a href="#" class="text-decoration-none text-secondary" data-bs-toggle="modal" data-bs-target="#support-modal">@helpdesk</a></span>
          </div>
        </div>
        
        <!-- subtle footer note (optional but adds polish) -->
        <div class="text-center text-muted mt-4 small opacity-75">
          <i class="bi bi-shield-check"></i> Automated monitoring active — 505: unexpected server condition
        </div>
      </div>
    </div>
  </div>

  <!-- SUPPORT MODAL (optional enhancement: quick contact/help window) -->
  <div class="modal fade" id="support-modal" tabindex="-1" aria-labelledby="supportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content rounded-4 border-0 shadow">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-semibold" id="supportModalLabel">
            <i class="bi bi-headset text-primary me-2"></i>Get in touch
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body pt-2">
          <p class="text-secondary">Our team is aware of the 505 error. If you need immediate assistance, you can reach us using the options below:</p>
          <ul class="list-unstyled">
            <li class="mb-2"><i class="bi bi-envelope-fill me-2 text-primary"></i> <strong>Email:</strong> <a href="mailto:support@example.com" class="text-decoration-none">support@example.com</a></li>
            <li class="mb-2"><i class="bi bi-chat-right-text-fill me-2 text-primary"></i> <strong>Live chat:</strong> available 9am–6pm UTC</li>
            <li class="mb-2"><i class="bi bi-twitter me-2 text-primary"></i> <strong>X (Twitter):</strong> @helpdesk</li>
          </ul>
          <div class="alert alert-light border rounded-3 p-2 mt-2 small">
            <i class="bi bi-clock-history me-1"></i> Typical resolution time: 15–30 minutes. We apologize for any inconvenience.
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
          <a href="mailto:support@example.com?subject=505%20Error%20Report" class="btn btn-accent text-white rounded-pill px-4">Email Support</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS Bundle (for modal and interactive behaviors) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <!-- tiny inline smooth console-free script for any dynamic enhancement (optional but ensures Back button works across modern browsers) -->
  <script>
    // additional robustness: gracefully handle any missing home link reference (already a proper href="/")
    // Also ensure go back button works even if history empty (fallback to homepage)
    const backBtn = document.querySelector('button[onclick="window.history.back();"]');
    if (backBtn) {
      // preserve existing behavior but add fallback edge case: 
      // replace with eventListener for cleaner code without inline onclick conflicts (optional but keeps consistency)
      // but we keep same logic: However to avoid double binding I'll override with addEventListener but keep default behavior
      // actually original inline works. but we add a safe fallback for when there is no history
      const originalBack = backBtn.getAttribute('onclick');
      backBtn.removeAttribute('onclick');
      backBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.href = '/';
        }
      });
    }
    // if homepage link is relative, it's fine; also ensure that contact modal links inside footer open modal without issue
    // add micro interaction: small console greeting for dev (but not intrusive)
    // simple animation to error code for modern delight? but already icon has floating animation — subtle & professional
    // Also ensure that all links with "#support-modal" trigger properly.
    document.querySelectorAll('[data-bs-toggle="modal"]').forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        // just guarantee bootstrap modal init, but bootstrap already handles
      });
    });
  </script>
  <!-- Ensure any dynamic / homepage link fallback when not in production demo environment -->
  <noscript>
    <div class="alert alert-warning text-center">JavaScript is recommended for full functionality, but core error page still works.</div>
  </noscript>
</body>
</html>