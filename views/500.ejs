<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>505 — Service Interruption | Please Retry</title>
  <!-- Bootstrap 5 CSS + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Font Awesome (optional, kept for consistency) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts: Inter + Fallback -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  
  <style>
    /* ----- GLOBAL DESIGN VARIABLES (refined, modern, accessible) ----- */
    :root {
      --primary: #2c5f8a;
      --primary-dark: #1e405e;
      --primary-light: #538eb3;
      --primary-soft: #eef4fa;
      --bg-light: #f8fafd;
      --gray-bg: #edf2f7;
      --text-dark: #1a2c3e;
      --text-muted: #4a627a;
      --text-light: #6c86a3;
      --border-light: #e2edf7;
      --border-focus: #cbdde9;
      --shadow-sm: 0 8px 20px rgba(0, 0, 0, 0.03), 0 2px 4px rgba(0, 0, 0, 0.02);
      --shadow-md: 0 20px 35px -12px rgba(0, 0, 0, 0.08);
      --transition-default: all 0.25s cubic-bezier(0.2, 0, 0, 1);
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      background: radial-gradient(circle at 10% 30%, var(--bg-light) 0%, var(--gray-bg) 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      margin: 0;
    }

    /* elevated error card — refined glassmorphism touch */
    .error-card {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(0px);
      border-radius: 2.5rem;
      box-shadow: var(--shadow-md), 0 1px 2px rgba(0,0,0,0.02);
      transition: var(--transition-default);
      border: 1px solid rgba(255,255,255,0.6);
      overflow: hidden;
    }

    .error-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 30px 45px -16px rgba(0, 0, 0, 0.12);
    }

    /* dynamic 505 code with gradient + subtle animation */
    .error-code {
      font-size: 7rem;
      font-weight: 800;
      line-height: 1.1;
      background: linear-gradient(125deg, var(--primary-dark) 0%, var(--primary) 48%, #3e7b9e 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.02em;
      text-shadow: 0 2px 5px rgba(44, 95, 138, 0.08);
    }

    /* floating server icon with graceful motion */
    @keyframes gentleFloat {
      0% { transform: translateY(0px) rotate(0deg); }
      55% { transform: translateY(-7px) rotate(1deg); }
      100% { transform: translateY(0px) rotate(0deg); }
    }

    .server-icon {
      font-size: 4.5rem;
      background: linear-gradient(135deg, var(--primary) 20%, var(--primary-light) 80%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      display: inline-block;
      animation: gentleFloat 3.2s ease-in-out infinite;
      filter: drop-shadow(0 6px 10px rgba(44, 95, 138, 0.2));
    }

    /* primary action button — refined modern */
    .btn-primary-custom {
      background: var(--primary);
      border: none;
      padding: 0.75rem 1.9rem;
      font-weight: 600;
      border-radius: 60px;
      transition: var(--transition-default);
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
      color: white;
    }

    .btn-primary-custom:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 12px 20px -12px rgba(30, 64, 94, 0.4);
      color: white;
    }

    .btn-outline-modern {
      border-radius: 60px;
      padding: 0.68rem 1.7rem;
      font-weight: 500;
      border: 1px solid var(--border-focus);
      background: white;
      color: var(--text-muted);
      transition: var(--transition-default);
    }

    .btn-outline-modern:hover {
      background-color: var(--bg-light);
      border-color: var(--primary-light);
      color: var(--primary-dark);
      transform: translateY(-1px);
    }

    /* status card / message bubble */
    .status-badge {
      background: var(--primary-soft);
      border-radius: 80px;
      padding: 0.5rem 1.2rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--primary-dark);
      border: 1px solid rgba(44, 95, 138, 0.15);
    }

    /* suggestion row cards */
    .suggestion-card {
      background: #ffffff;
      border-radius: 1.25rem;
      padding: 0.65rem 1rem;
      transition: var(--transition-default);
      border: 1px solid var(--border-light);
    }

    .suggestion-card:hover {
      background: var(--bg-light);
      border-color: var(--primary-light);
    }

    /* help text refined */
    .help-footer {
      border-top: 1px solid var(--border-light);
      padding-top: 1.25rem;
      font-size: 0.85rem;
    }

    .help-footer a {
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .help-footer a:hover {
      color: var(--primary);
      text-decoration: underline;
    }

    /* responsiveness */
    @media (max-width: 576px) {
      .error-card { padding: 1.8rem 1.2rem !important; }
      .error-code { font-size: 4.5rem; }
      .server-icon { font-size: 3rem; }
      .btn-primary-custom, .btn-outline-modern {
        width: 100%;
        text-align: center;
        justify-content: center;
      }
      .button-group {
        flex-direction: column;
        gap: 0.8rem !important;
      }
      .status-badge { font-size: 0.75rem; padding: 0.35rem 1rem; }
    }

    @media (min-width: 768px) {
      .error-code { font-size: 9rem; }
      .server-icon { font-size: 5rem; }
    }

    /* modal enhancements */
    .modal-content {
      border-radius: 1.75rem;
      border: none;
    }
    .modal-header {
      border-bottom: 1px solid var(--border-light);
    }
    .btn-close:focus {
      box-shadow: none;
    }
    a, button {
      transition: var(--transition-default);
    }
    .text-secondary-hover {
      transition: color 0.2s;
    }
  </style>
</head>
<body>

<div class="container py-3 py-md-4">
  <div class="row justify-content-center align-items-center" style="min-height: 95vh;">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7">
      
      <!-- main error card with pristine spacing and visual rhythm -->
      <div class="error-card p-4 p-md-5 text-center">
        
        <!-- hero icon + code with brand identity -->
        <div class="mb-4">
          <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap">
            <i class="bi bi-hdd-stack-fill server-icon"></i>
            <span class="error-code">505</span>
          </div>
          <div class="mt-3">
            <span class="status-badge">
              <i class="bi bi-exclamation-triangle-fill"></i> HTTP 505 · Unexpected Server Condition
            </span>
          </div>
        </div>

        <!-- human centered messaging -->
        <h1 class="h3 fw-bold mb-2" style="color: var(--text-dark);">Temporary service hiccup</h1>
        <p class="lead fs-5" style="color: var(--text-muted); max-width: 480px; margin-left: auto; margin-right: auto;">
          Our server encountered an unexpected condition. The issue is being resolved.
        </p>
        
        <!-- informational reassurance panel (gentle alert style) -->
        <div class="mx-auto mb-4" style="max-width: 500px;">
          <div class="d-flex align-items-center justify-content-center gap-2 bg-white rounded-4 p-3 border border-light shadow-sm">
            <i class="bi bi-megaphone-fill text-primary fs-5"></i>
            <span class="small fw-medium" style="color: var(--text-dark);">Our engineering team was notified automatically — no action required from you.</span>
          </div>
        </div>

        <!-- practical action suggestions (clean, modern cards) -->
        <div class="row g-3 mb-4 text-start">
          <div class="col-md-6">
            <div class="suggestion-card d-flex align-items-center gap-3">
              <i class="bi bi-arrow-repeat fs-4 text-primary"></i>
              <div>
                <strong class="d-block" style="color: var(--text-dark);">Refresh after short wait</strong>
                <span class="small text-secondary">Usually resolves in 2-3 minutes</span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="suggestion-card d-flex align-items-center gap-3">
              <i class="bi bi-house-heart fs-4 text-primary"></i>
              <div>
                <strong class="d-block" style="color: var(--text-dark);">Return to homepage</strong>
                <span class="small text-secondary">Start fresh from main portal</span>
              </div>
            </div>
          </div>
        </div>

        <!-- call to action buttons group (improved accessibility) -->
        <div class="button-group d-flex flex-wrap justify-content-center gap-3 mt-2 mb-4">
          <a href="/" class="btn btn-primary-custom px-4 py-2 d-inline-flex align-items-center gap-2">
            <i class="bi bi-house-door-fill"></i> Back to Homepage
          </a>
          <button id="smartGoBackBtn" class="btn btn-outline-modern d-inline-flex align-items-center gap-2">
            <i class="bi bi-arrow-left-short"></i> Previous Page
          </button>
          <button type="button" data-bs-toggle="modal" data-bs-target="#supportModal" class="btn btn-outline-modern d-inline-flex align-items-center gap-2">
            <i class="bi bi-headset"></i> Contact Support
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- SUPPORT MODAL (enhanced with direct reporting and design consistency) -->
<div class="modal fade" id="supportModal" tabindex="-1" aria-labelledby="supportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-md">
    <div class="modal-content rounded-4 border-0 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-semibold fs-5" id="supportModalLabel">
          <i class="bi bi-chat-right-heart-fill text-primary me-2"></i>We're here to help
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2 pb-2">
        <p class="text-secondary mb-3">Our infrastructure monitors this 505 condition. For urgent assistance, use any channel below:</p>
        <div class="bg-light rounded-3 p-3 mb-3">
          <div class="d-flex flex-column gap-2">
            <div><i class="bi bi-envelope-fill text-primary me-2" style="width: 1.5rem;"></i> <strong>Email support:</strong> <a href="mailto:support@example.com?subject=505%20Error%20Report" class="text-decoration-none">support@example.com</a></div>
            <div><i class="bi bi-telephone-fill text-primary me-2"></i> <strong>Hotline:</strong> +1 (555) 202-9505 (Priority)</div>
            <div><i class="bi bi-twitter-x text-primary me-2"></i> <strong>X (Twitter):</strong> @servicestatus</div>
            <div><i class="bi bi-slack text-primary me-2"></i> <strong>Slack community:</strong> (invite on request)</div>
          </div>
        </div>
        <div class="alert alert-primary border-0 bg-primary-soft rounded-3 py-2 px-3 small" style="background: #eef4fc; color: #1e405e;">
          <i class="bi bi-graph-up me-1"></i> <strong>Estimated resolution:</strong> Under 20 minutes · No data loss expected.
        </div>
        <p class="small text-secondary mt-2 mb-0"><i class="bi bi-shield-lock-fill me-1"></i> If you're in a critical flow, our support team will prioritize your ticket.</p>
      </div>
      <div class="modal-footer border-0 pt-0 pb-4">
        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Dismiss</button>
        <a href="mailto:support@example.com?subject=505%20Error%20%7C%20Immediate%20assistance" class="btn btn-primary-custom rounded-pill px-4">Email Support Now</a>
      </div>
    </div>
  </div>
</div>

<!-- Bootstrap JS + refined inline scripts for smarter UX and fallback reliability -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
<script>
  (function() {
    // ========== SMART BACK BUTTON WITH FALLBACK ==========
    const backButton = document.getElementById('smartGoBackBtn');
    if (backButton) {
      backButton.addEventListener('click', (e) => {
        e.preventDefault();
        // Check if there is previous page in history (safely)
        if (window.history.length > 1 && document.referrer && document.referrer !== "") {
          window.history.back();
        } else if (window.history.length > 1) {
          window.history.back();
        } else {
          // graceful fallback to homepage if no history state
          window.location.href = '/';
        }
      });
    }

    // ========== ENHANCE ALL MODAL TRIGGERS ==========
    // Ensure any dynamically added or existing modal triggers work smoothly
    const modalTriggers = document.querySelectorAll('[data-bs-toggle="modal"]');
    modalTriggers.forEach(trigger => {
      // prevent multiple listeners, but just guarantee bootstrap modal init already works.
      // we also improve UX: if the trigger uses href but not prevented, ensure modal opens.
      trigger.addEventListener('click', function(ev) {
        // no extra action needed - bootstrap already does heavy lifting,
        // but ensure that if target modal exists, it's correctly displayed.
        const targetModalId = this.getAttribute('data-bs-target');
        if (targetModalId && document.querySelector(targetModalId)) {
          // just to be safe, bootstrap modal will handle; but we make sure no duplicate error
        }
      });
    });
    
    // ========== ADD RETRY STATUS SIMULATION / MICRO INTERACTION ==========
    // Provide a subtle copy about retry if user clicks on status badge (optional)
    const statusBadge = document.querySelector('.status-badge');
    if (statusBadge) {
      statusBadge.style.cursor = 'default';
      statusBadge.setAttribute('title', 'Auto-retry in progress — please wait a moment');
    }
    
    // ========== ADD CONSOLE-FRIENDLY HELPER (non-intrusive) ==========
    // If the user is stuck and clicks "Return to Homepage", we ensure absolute path handling.
    const homeLinks = document.querySelectorAll('a[href="/"]');
    homeLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        // default behavior is fine, but we could add a tiny preloader message? optional clean.
        // no modification needed.
      });
    });

    // ========== RELOAD ADVICE FOR PERSISTENT ERRORS ==========
    // Optional small keyboard hint: detect if user presses "r" to refresh?
    // it's non-obtrusive but handy for power users
    window.addEventListener('keydown', (e) => {
      if (e.key === 'r' && (e.ctrlKey || e.metaKey)) {
        // do not override native refresh; we just optionally provide console hint but avoid console noise.
        return;
      }
      if (e.key === 'F5') {
        return;
      }
    });

    // ========== PREVENT INLINE CONFLICTS WITH OLD HISTORY BUTTON ==========
    // Remove any leftover inline onclick if present (to avoid double calls)
    const possibleOldBackBtn = document.querySelector('button[onclick*="history.back"]');
    if (possibleOldBackBtn && possibleOldBackBtn.id !== 'smartGoBackBtn') {
      possibleOldBackBtn.removeAttribute('onclick');
    }
    
    // ========== ACCESSIBILITY ENHANCEMENT ==========
    // ensure focus rings are visible in interactive elements
    const allInteractive = document.querySelectorAll('a, button, [tabindex="0"]');
    allInteractive.forEach(el => {
      if (el.style.outline === '') {
        el.addEventListener('focus', () => {
          el.style.outline = '2px solid var(--primary)';
          el.style.outlineOffset = '2px';
        });
        el.addEventListener('blur', () => {
          el.style.outline = '';
        });
      }
    });
  })();
</script>

<!-- optional noscript fallback message for accessibility -->
<noscript>
  <div class="container mt-5">
    <div class="alert alert-warning text-center rounded-4 shadow-sm">
      <strong>JavaScript is off, but core navigation works.</strong> Please refresh the page or contact support via email.
    </div>
  </div>
</noscript>

</body>
</html>