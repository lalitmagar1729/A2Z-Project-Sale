<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Portfolio | Modern Project Showcase</title>
  <!-- Bootstrap 5 CSS + Icons (Bootstrap Icons for cart/view icons optional but clean) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Google Fonts: Poppins + Roboto fallback -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free icons for modern feel, optional but adds flair) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* ----- NO GLOBAL STYLES: only scoped to .project-page container & card components ----- */
    /* Everything is prefixed with .project-container or .project-card to avoid global leakage */
    
    .project-page {
      background: #f8fafc;   /* soft gray-blue background for page depth */
      font-family: 'Poppins', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }

    /* Header section - clean modern */
    .portfolio-header {
      text-align: center;
      max-width: 720px;
      margin: 0 auto;
    }

    .portfolio-header .badge-accent {
      display: inline-block;
      background: #e0f2fe;
      color: #0c4e6e;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.35rem 1rem;
      border-radius: 40px;
      letter-spacing: 0.3px;
      margin-bottom: 1rem;
    }

    .portfolio-header h1 {
      font-weight: 700;
      font-size: 2.8rem;
      background: linear-gradient(135deg, #1e2a3a 0%, #0f2b3d 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.02em;
    }

    .portfolio-header .lead {
      color: #334155;
      font-weight: 400;
      font-size: 1.1rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    /* custom card styling: no global overrides, only within .project-card-wrapper */
    .project-card {
      background: #ffffff;
      border: none;
      border-radius: 1.25rem;
      transition: transform 0.25s ease, box-shadow 0.3s ease;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.03), 0 2px 6px rgba(0, 0, 0, 0.05);
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    /* Hover effect: lift + stronger shadow */
    .project-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15), 0 4px 12px rgba(0, 0, 0, 0.05);
    }

    /* Image container with subtle zoom on hover */
    .card-img-top-wrapper {
      overflow: hidden;
      background-color: #eef2f6;
      border-top-left-radius: 1.25rem;
      border-top-right-radius: 1.25rem;
    }

    .project-img {
      width: 100%;
      aspect-ratio: 16 / 10;  /* consistent aspect ratio for all thumbnails */
      object-fit: cover;
      transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      display: block;
    }

    .project-card:hover .project-img {
      transform: scale(1.05);
    }

    /* card body */
    .project-card .card-body {
      padding: 1.5rem 1.25rem 1.25rem 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .project-title {
      font-weight: 700;
      font-size: 1.35rem;
      margin-bottom: 0.65rem;
      color: #0f172a;
      letter-spacing: -0.2px;
      line-height: 1.3;
    }

    .project-description {
      color: #475569;
      font-size: 0.9rem;
      line-height: 1.5;
      margin-bottom: 1rem;
      font-weight: 400;
      flex: 1;
    }

    /* price styling */
    .project-price {
      font-weight: 700;
      font-size: 1.3rem;
      color: #1e6f5c;   /* modern teal accent */
      margin-bottom: 1.1rem;
      display: flex;
      align-items: baseline;
      gap: 5px;
    }
    .project-price small {
      font-size: 0.8rem;
      font-weight: 500;
      color: #5b6e8c;
    }

    /* button row with consistent styling */
    .card-buttons {
      display: flex;
      gap: 12px;
      margin-top: 0.2rem;
    }

    .btn-outline-details {
      background: transparent;
      border: 1.5px solid #cbd5e1;
      color: #1e293b;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 0.45rem 0.9rem;
      border-radius: 2rem;
      transition: all 0.2s ease;
      flex: 1;
      text-align: center;
    }

    .btn-outline-details:hover {
      background-color: #f1f5f9;
      border-color: #94a3b8;
      color: #0f172a;
      transform: translateY(-2px);
    }

    .btn-teal-cart {
      background: #1e6f5c;
      border: none;
      color: white;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 0.45rem 0.9rem;
      border-radius: 2rem;
      transition: all 0.2s ease;
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-teal-cart:hover {
      background: #0e5e4b;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(30, 111, 92, 0.3);
      color: white;
    }

    /* responsive adjustments */
    @media (max-width: 768px) {
      .portfolio-header h1 {
        font-size: 2rem;
      }
      .project-title {
        font-size: 1.2rem;
      }
      .card-buttons {
        flex-wrap: wrap;
      }
      .btn-outline-details, .btn-teal-cart {
        font-size: 0.8rem;
        padding: 0.4rem 0.6rem;
      }
    }

    /* footer minimal (not global style) */
    .project-footer {
      border-top: 1px solid rgba(0,0,0,0.05);
      background: transparent;
      color: #5b6e8c;
    }
  </style>
</head>
