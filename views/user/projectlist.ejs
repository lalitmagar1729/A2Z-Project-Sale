<%- include("navbar.ejs") %>
  <style>
    /* ----- NO GLOBAL STYLES: only scoped to .project-page container & card components ----- */
    /* Everything is prefixed with .project-container or .project-card to avoid global leakage */

    .project-page {
      background: #f8fafc;
      /* soft gray-blue background for page depth */
      font-family: 'Poppins', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }

    /* Header section - clean modern */
    .portfolio-header {
      text-align: center;
      max-width: 720px;
      margin: 0 auto;
    }

    .portfolio-header .badge-accent {
      display: inline-block;
      background: #e0f2fe;
      color: #0c4e6e;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.35rem 1rem;
      border-radius: 40px;
      letter-spacing: 0.3px;
      margin-bottom: 1rem;
    }

    .portfolio-header h1 {
      font-weight: 700;
      font-size: 2.8rem;
      background: linear-gradient(135deg, #1e2a3a 0%, #0f2b3d 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.02em;
    }

    .portfolio-header .lead {
      color: #334155;
      font-weight: 400;
      font-size: 1.1rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    /* custom card styling: no global overrides, only within .project-card-wrapper */
    .project-card {
      background: #ffffff;
      border: none;
      border-radius: 1.25rem;
      transition: transform 0.25s ease, box-shadow 0.3s ease;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.03), 0 2px 6px rgba(0, 0, 0, 0.05);
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    /* Hover effect: lift + stronger shadow */
    .project-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15), 0 4px 12px rgba(0, 0, 0, 0.05);
    }

    /* Image container with subtle zoom on hover */
    .card-img-top-wrapper {
      overflow: hidden;
      background-color: #eef2f6;
      border-top-left-radius: 1.25rem;
      border-top-right-radius: 1.25rem;
    }

    .project-img {
      width: 100%;
      aspect-ratio: 16 / 10;
      /* consistent aspect ratio for all thumbnails */
      object-fit: cover;
      transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      display: block;
    }

    .project-card:hover .project-img {
      transform: scale(1.05);
    }

    /* card body */
    .project-card .card-body {
      padding: 1.5rem 1.25rem 1.25rem 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .project-title {
      font-weight: 700;
      font-size: 1.35rem;
      margin-bottom: 0.65rem;
      color: #0f172a;
      letter-spacing: -0.2px;
      line-height: 1.3;
    }

    .project-description {
      color: #475569;
      font-size: 0.9rem;
      line-height: 1.5;
      margin-bottom: 1rem;
      font-weight: 400;
      flex: 1;
    }

    /* price styling */
    .project-price {
      font-weight: 700;
      font-size: 1.3rem;
      color: #1e6f5c;
      /* modern teal accent */
      margin-bottom: 1.1rem;
      display: flex;
      align-items: baseline;
      gap: 5px;
    }

    .project-price small {
      font-size: 0.8rem;
      font-weight: 500;
      color: #5b6e8c;
    }

    /* button row with consistent styling */
    .card-buttons {
      display: flex;
      gap: 12px;
      margin-top: 0.2rem;
    }

    .btn-outline-details {
      background: transparent;
      border: 1.5px solid #cbd5e1;
      color: #1e293b;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 0.45rem 0.9rem;
      border-radius: 2rem;
      transition: all 0.2s ease;
      flex: 1;
      text-align: center;
    }

    .btn-outline-details:hover {
      background-color: #f1f5f9;
      border-color: #94a3b8;
      color: #0f172a;
      transform: translateY(-2px);
    }

    .btn-teal-cart {
      background: #1e6f5c;
      border: none;
      color: white;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 0.45rem 0.9rem;
      border-radius: 2rem;
      transition: all 0.2s ease;
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-teal-cart:hover {
      background: #0e5e4b;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(30, 111, 92, 0.3);
      color: white;
    }

    /* responsive adjustments */
    @media (max-width: 768px) {
      .portfolio-header h1 {
        font-size: 2rem;
      }

      .project-title {
        font-size: 1.2rem;
      }

      .card-buttons {
        flex-wrap: wrap;
      }

      .btn-outline-details,
      .btn-teal-cart {
        font-size: 0.8rem;
        padding: 0.4rem 0.6rem;
      }
    }

    /* footer minimal (not global style) */
    .project-footer {
      border-top: 1px solid rgba(0, 0, 0, 0.05);
      background: transparent;
      color: #5b6e8c;
    }

    /* Wishlist Button */
    .card-img-top-wrapper {
      position: relative;
      overflow: hidden;
    }

    .wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      background: white;
      border: none;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      z-index: 10;
    }

    .wishlist-btn i {
      font-size: 18px;
      color: #666;
      transition: color 0.3s ease;
    }

    .wishlist-btn:hover {
      transform: scale(1.1);
    }

    .wishlist-btn:hover i {
      color: #e74c3c;
    }

    .wishlist-btn.active i {
      color: #e74c3c;
      font-family: "Font Awesome 6 Free";
      font-weight: 900;
    }

    /* Technology Tags */
    .project-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 15px;
    }

    .tech-tag {
      background: #f0f4f8;
      color: #2c3e50;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.3px;
      transition: all 0.2s ease;
    }

    .tech-tag:hover {
      background: #e2e8f0;
      transform: translateY(-1px);
    }

    /* Optional: Different colors for different tech tags (using data attributes or additional classes) */
    .tech-tag[data-tech="react"] {
      background: #61dafb20;
      color: #61dafb;
    }

    .tech-tag[data-tech="node"] {
      background: #68a06320;
      color: #68a063;
    }
    /* Enhanced Pagination Styling */
.pagination {
  gap: 5px;
}

.page-item {
  margin: 0 2px;
}

.page-link {
  border-radius: 8px;
  padding: 10px 16px;
  color: #2c3e50;
  background-color: #fff;
  border: 1px solid #dee2e6;
  transition: all 0.3s ease;
  font-weight: 500;
}

.page-link:hover {
  background-color: #f8f9fa;
  border-color: #dee2e6;
  color: #14b8a6;
  transform: translateY(-2px);
}

.page-item.active .page-link {
  background-color: #14b8a6;
  border-color: #14b8a6;
  color: white;
  box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);
}

.page-item.disabled .page-link {
  color: #adb5bd;
  pointer-events: none;
  background-color: #fff;
  border-color: #dee2e6;
}

.page-link i {
  font-size: 12px;
}

/* Responsive Pagination */
@media (max-width: 768px) {
  .page-link {
    padding: 6px 12px;
    font-size: 14px;
  }
  
  .pagination {
    gap: 3px;
  }
}
  </style>
