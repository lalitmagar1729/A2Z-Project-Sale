<!-- Optional subtle animation for stat counters (demo) - simple, numbers stay as static but we add dynamic counting effect for better engagement -->
<script>
  // A small script to count-up stats when they come into view (purely aesthetic)
  // Not required but adds modern feeling. All stat numbers are already displayed in HTML.
  (function() {
    const statNumbers = document.querySelectorAll('.stat-number');
    // store original text content
    const updateNumber = (el, targetNum) => {
      let current = 0;
      const increment = Math.ceil(targetNum / 40);
      const timer = setInterval(() => {
        current += increment;
        if(current >= targetNum) {
          el.innerText = targetNum.toLocaleString() + (el.innerText.includes('+') ? '+' : '');
          clearInterval(timer);
        } else {
          el.innerText = current + (el.innerText.includes('+') ? '+' : '');
        }
      }, 20);
    };
    // Parse numbers from text (500+, 2000+, 50+, 1500+)
    const statsData = [
      { elem: statNumbers[0], raw: 500, suffix: '+' },
      { elem: statNumbers[1], raw: 2000, suffix: '+' },
      { elem: statNumbers[2], raw: 50, suffix: '+' },
      { elem: statNumbers[3], raw: 1500, suffix: '+' }
    ];
    // Intersection Observer to trigger count-up only once
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting) {
          const targetElem = entry.target;
          const data = statsData.find(s => s.elem === targetElem);
          if(data && !targetElem.getAttribute('data-counted')) {
            targetElem.setAttribute('data-counted', 'true');
            let targetNumber = data.raw;
            let currentNum = 0;
            const step = Math.ceil(targetNumber / 45);
            const interval = setInterval(() => {
              currentNum += step;
              if(currentNum >= targetNumber) {
                targetElem.innerText = targetNumber.toLocaleString() + data.suffix;
                clearInterval(interval);
              } else {
                targetElem.innerText = currentNum + data.suffix;
              }
            }, 20);
          }
        }
      });
    }, { threshold: 0.5 });
    statsData.forEach(stat => {
      if(stat.elem) observer.observe(stat.elem);
    });
    // Fallback: if observer not needed, still ensure format
    statsData.forEach(stat => {
      if(stat.elem && !stat.elem.getAttribute('data-init')) {
        stat.elem.setAttribute('data-init', 'true');
        stat.elem.innerText = stat.raw.toLocaleString() + stat.suffix;
      }
    });
  })();
</script>
