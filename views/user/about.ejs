    <!-- ========== SCRIPT: Intersection Observer for stat counters (isolated inside this page) ========== -->
    <script>
      (function() {
        // Target all stat numbers inside .about-page-root
        const statElements = [
          { elem: document.getElementById('aboutStatProjects'), raw: 500, suffix: '+' },
          { elem: document.getElementById('aboutStatBuyers'), raw: 2000, suffix: '+' },
          { elem: document.getElementById('aboutStatStacks'), raw: 50, suffix: '+' },
          { elem: document.getElementById('aboutStatStudents'), raw: 1500, suffix: '+' }
        ].filter(item => item.elem);
        
        // Initialize default values
        statElements.forEach(stat => {
          if (stat.elem && !stat.elem.getAttribute('data-counted-init')) {
            stat.elem.setAttribute('data-counted-init', 'true');
            stat.elem.innerText = stat.raw.toLocaleString() + stat.suffix;
          }
        });
        
        // Count-up function using requestAnimationFrame smoothness
        function startCountUp(el, target, suffix) {
          if (el.getAttribute('data-animated') === 'true') return;
          el.setAttribute('data-animated', 'true');
          let current = 0;
          const duration = 1000;
          const stepTime = 16;
          const steps = duration / stepTime;
          const increment = target / steps;
          let step = 0;
          const timer = setInterval(() => {
            step++;
            current += increment;
            if (step >= steps) {
              el.innerText = target.toLocaleString() + suffix;
              clearInterval(timer);
            } else {
              el.innerText = Math.floor(current).toLocaleString() + suffix;
            }
          }, stepTime);
        }
        
        // Intersection Observer with threshold
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const targetElem = entry.target;
              const statData = statElements.find(s => s.elem === targetElem);
              if (statData && !targetElem.getAttribute('data-animated')) {
                startCountUp(targetElem, statData.raw, statData.suffix);
              }
            }
          });
        }, { threshold: 0.5 });
        
        statElements.forEach(stat => {
          if (stat.elem) observer.observe(stat.elem);
        });
      })();
    </script>
