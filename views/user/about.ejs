<style>
  /* ============================================ */
  /* MODERATE SIZED TESTIMONIAL SLIDER CSS       */
  /* BALANCED - NOT TOO BIG, NOT TOO SMALL       */
  /* ============================================ */

  .testimonial-slider-wrapper {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
    padding: 0 45px;
  }

  .testimonial-slider-container {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
  }

  .testimonial-slider {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: grab;
  }

  .testimonial-slider:active {
    cursor: grabbing;
  }

  .testimonial-slide {
    flex: 0 0 100%;
    padding: 12px;
    box-sizing: border-box;
  }

  /* Moderate Card Size */
  .testimonial-single-card {
    background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFF 100%);
    border-radius: 24px;
    padding: 1.8rem;
    text-align: center;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
    border: 1px solid rgba(107, 140, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  .testimonial-single-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #6B8CFF, #A5B9FF, #6B8CFF);
  }

  .testimonial-single-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 35px rgba(0, 0, 0, 0.1);
  }

  /* Quote Icon - Smaller */
  .quote-icon {
    margin-bottom: 1rem;
  }

  .quote-icon i {
    font-size: 2rem;
    color: #6B8CFF;
    opacity: 0.4;
    font-family: 'Georgia', serif;
  }

  /* Testimonial Text - Moderate */
  .testimonial-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #2C3E50;
    margin-bottom: 1.5rem;
    font-style: italic;
    position: relative;
    z-index: 1;
    max-height: 100px;
    overflow-y: auto;
  }

  /* Custom scrollbar for text */
  .testimonial-text::-webkit-scrollbar {
    width: 3px;
  }

  .testimonial-text::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }

  .testimonial-text::-webkit-scrollbar-thumb {
    background: #6B8CFF;
    border-radius: 10px;
  }

  /* Author Section - Compact */
  .testimonial-author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 0.75rem;
  }

  .author-avatar i {
    font-size: 2.2rem;
    color: #6B8CFF;
    background: rgba(107, 140, 255, 0.1);
    border-radius: 50%;
  }

  .author-info h6 {
    font-size: 0.9rem;
    margin-bottom: 2px;
    color: #1a2a4a;
  }

  .author-info small {
    font-size: 0.7rem;
    color: #6c757d;
  }

  /* Rating Stars - Smaller */
  .rating-stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-top: 0.25rem;
  }

  .rating-stars i {
    color: #FFB800;
    font-size: 0.85rem;
  }

  /* Navigation Buttons - Moderate */
  .slider-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: white;
    border: 1px solid rgba(107, 140, 255, 0.2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
  }

  .slider-nav i {
    font-size: 1.2rem;
    color: #3D5AFE;
  }

  .slider-nav:hover {
    background: linear-gradient(135deg, #6B8CFF, #3D5AFE);
    border-color: transparent;
    transform: translateY(-50%) scale(1.05);
  }

  .slider-nav:hover i {
    color: white;
  }

  .prev-nav {
    left: -15px;
  }

  .next-nav {
    right: -15px;
  }

  /* Dots Indicator - Smaller */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 25px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #CBD5E1;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot:hover {
    background: #6B8CFF;
    transform: scale(1.2);
  }

  .dot.active {
    width: 24px;
    border-radius: 20px;
    background: linear-gradient(135deg, #6B8CFF, #3D5AFE);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .testimonial-slider-wrapper {
      max-width: 550px;
      padding: 0 35px;
    }
    
    .testimonial-single-card {
      padding: 1.4rem;
    }
    
    .testimonial-text {
      font-size: 0.85rem;
      line-height: 1.5;
      max-height: 85px;
    }
    
    .slider-nav {
      width: 32px;
      height: 32px;
    }
    
    .slider-nav i {
      font-size: 1rem;
    }
    
    .prev-nav {
      left: -10px;
    }
    
    .next-nav {
      right: -10px;
    }
    
    .quote-icon i {
      font-size: 1.6rem;
    }
    
    .author-avatar i {
      font-size: 1.8rem;
    }
    
    .author-info h6 {
