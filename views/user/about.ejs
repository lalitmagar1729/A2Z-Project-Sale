    }
  }

  @media (max-width: 576px) {
    .slider-nav {
      display: none;
    }
    
    .testimonial-slider-wrapper {
      padding: 0;
      max-width: 100%;
    }
    
    .testimonial-single-card {
      padding: 1.2rem;
    }
    
    .testimonial-text {
      font-size: 0.8rem;
      max-height: 80px;
