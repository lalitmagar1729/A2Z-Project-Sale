<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ProjectMarket | Premium Projects</title>

  <!-- Bootstrap 5 CSS + Icons + Google Fonts -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
    rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Preconnect for performance -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
    rel="stylesheet">



  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* Navbar Main Container */
    .gradient-navbar {
      background: linear-gradient(105deg, #0B1120 0%, #16203A 40%, #1F2B4E 100%);
      padding: 0.75rem 2rem;
      box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.3), 0 1px 2px rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transition: all 0.3s ease;
      font-family: 'Inter', sans-serif;
      width: 100%;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    /* Brand / Logo styling */
    .gradient-navbar .navbar-brand {
      font-size: 1.65rem;
      font-weight: 700;
      background: linear-gradient(120deg, #FFFFFF, #A5B9FF, #7C93FF);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.3px;
      transition: transform 0.2s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
    }

    .gradient-navbar .navbar-brand i {
      background: linear-gradient(135deg, #6B8CFF, #3D5AFE);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      font-size: 1.5rem;
      margin-right: 8px;
    }

    .gradient-navbar .navbar-brand:hover {
      transform: scale(1.02);
    }

    /* Nav links styling - all items on right side */
    .gradient-navbar .navbar-nav {
      gap: 0.25rem;
      margin-left: auto !important;
    }

    .gradient-navbar .nav-link {
      color: rgba(255, 255, 255, 0.85);
      font-weight: 500;
      font-size: 0.95rem;
      padding: 0.55rem 1.1rem;
      border-radius: 50px;
      transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      position: relative;
    }

    .gradient-navbar .nav-link i {
      font-size: 1rem;
      transition: transform 0.2s;
    }

    .gradient-navbar .nav-link:hover {
      background: rgba(255, 255, 255, 0.12);
      color: white;
      transform: translateY(-2px);
    }

    /* ============================================ */
    /* ACTIVE PAGE UNDERLINE EFFECT                 */
    /* ============================================ */

    .gradient-navbar .nav-link.active {
      background: transparent;
      color: white;
      border-left: none;
    }

    .gradient-navbar .nav-link.active::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      transform: translateX(-50%);
      width: 70%;
      height: 3px;
      background: linear-gradient(90deg, #6B8CFF, #A5B9FF, #6B8CFF);
      border-radius: 3px;
      animation: underlineSlide 0.3s ease-out;
    }

    /* Underline animation */
    @keyframes underlineSlide {
      from {
        width: 0%;
        opacity: 0;
      }

      to {
        width: 70%;
        opacity: 1;
      }
    }

    /* Hover underline effect for non-active links */
    .gradient-navbar .nav-link:not(.active)::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      transform: translateX(-50%);
      width: 0%;
      height: 2px;
      background: linear-gradient(90deg, #6B8CFF, #A5B9FF);
      border-radius: 3px;
      transition: width 0.25s ease;
    }

    .gradient-navbar .nav-link:not(.active):hover::after {
      width: 50%;
    }

    /* Badge for wishlist/cart */
    .navbar-badge {
      background: linear-gradient(135deg, #FF4D6D, #C9184A);
      color: white;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0.2rem 0.55rem;
      border-radius: 40px;
      margin-left: 6px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
      display: inline-block;
      line-height: 1.3;
    }

    /* Position relative for badge positioning */
    .gradient-navbar .position-relative {
      position: relative;
    }

    /* Mobile Toggler Button */
    .navbar-gradient-toggler {
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: rgba(255, 255, 255, 0.05);
      padding: 0.5rem 0.8rem;
      border-radius: 8px;
      cursor: pointer;
    }

    .navbar-gradient-toggler:focus {
      box-shadow: 0 0 0 3px rgba(107, 140, 255, 0.5);
      outline: none;
    }

    .navbar-gradient-toggler i {
      font-size: 1.3rem;
      color: white;
    }

    /* Dropdown menu styling */
    .gradient-navbar .dropdown-menu {
      background: #0F172A;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(12px);
      border-radius: 12px;
      padding: 0.5rem 0;
      margin-top: 0.5rem;
    }

    .gradient-navbar .dropdown-item {
      color: rgba(255, 255, 255, 0.85);
      padding: 0.5rem 1rem;
      transition: all 0.2s;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .gradient-navbar .dropdown-item:hover {
      background: rgba(107, 140, 255, 0.3);
      color: white;
    }

    .gradient-navbar .dropdown-item i {
      width: 20px;
      font-size: 0.9rem;
    }

    .gradient-navbar .dropdown-divider {
      border-top-color: rgba(255, 255, 255, 0.1);
      margin: 0.3rem 0;
    }

    /* Container fluid padding */
    .gradient-navbar .container-fluid {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      width: 100%;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
    }

    /* Collapse animation */
    .gradient-navbar .navbar-collapse {
      flex-grow: 1;
      align-items: center;
    }

    /* Responsive adjustments */
    @media (max-width: 991.98px) {
      .gradient-navbar {
        padding: 0.7rem 1rem;
      }

      .gradient-navbar .nav-link {
        padding: 0.5rem 0.8rem;
      }

      .gradient-navbar .navbar-nav {
        margin-top: 0.5rem;
        margin-left: 0 !important;
      }

      .gradient-navbar .container-fluid {
        padding-left: 1rem;
        padding-right: 1rem;
      }

      /* Adjust underline for mobile */
      .gradient-navbar .nav-link.active::after {
        width: 40%;
      }

      .gradient-navbar .nav-link::after {
        bottom: -2px;
      }
    }

    @media (max-width: 575.98px) {
      .gradient-navbar .navbar-brand {
        font-size: 1.3rem;
      }

      .gradient-navbar .navbar-brand i {
        font-size: 1.2rem;
      }

      .gradient-navbar .nav-link {
        font-size: 0.85rem;
        padding: 0.4rem 0.7rem;
      }

      .gradient-navbar .nav-link.active::after {
        width: 30%;
      }
    }

    /* Animation for navbar */
    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .gradient-navbar {
      animation: slideDown 0.4s ease-out;
    }
  </style>


<body>

