<%- include('navbar.ejs') %>


  <!-- Navbar placeholder (as original, but now we can optionally keep same style) -->
  <div id="navbar-placeholder"></div>

  <main>
    <!-- Bootstrap container > row > column structure for main content -->
    <div class="container py-3">
      <!-- Hero Section (grid aligned) -->
      <div class="hero p-4 p-lg-5 mb-5">
        <div class="row align-items-center g-4">
          <div class="col-md-8">
            <div class="hero-text">
              <h1 class="display-4 fw-bold" style="color: var(--primary-dark);">Premium <span class="text-custom-accent">Projects</span><br>for Students</h1>
              <p class="mt-3 mb-4" style="color: var(--text-muted); font-size: 1.1rem;">✅ Full Source Code + Documentation ✅ Certificate of Ownership ✅ Live Demo</p>
              <button class="btn-primary-custom" onclick="scrollToProjects()">Explore Projects →</button>
            </div>
          </div>
          <div class="col-md-4 text-center text-md-end">
            <i class="fas fa-laptop-code" style="font-size: 90px; color: var(--primary-light);"></i>
          </div>
        </div>
      </div>

      <!-- Shop by Category (section) -->
      <div class="section-title-custom">
        <i class="fas fa-th-large"></i> Shop by Category
      </div>
      <div class="row g-4 mb-5" id="categoriesGrid"></div>

      <!-- Featured Projects -->
      <div class="section-title-custom">
        <i class="fas fa-star"></i> Featured & Top Selling
      </div>
      <div class="row g-4 mb-5" id="featuredGrid"></div>

      <!-- Testimonials Section (Bootstrap row/col but preserve original look) -->
      <div class="testimonials bg-custom-gray rounded-4 p-4 p-lg-5 my-5 text-center">
        <h2 style="color: var(--primary-dark);">What Our Clients Say</h2>
        <p style="color: var(--text-muted);">Trusted by students worldwide</p>
        <div class="row g-4 mt-2" id="testimonialsGrid"></div>
      </div>

      <!-- Call to Action Banner -->
      <div class="cta-banner-custom p-4 p-lg-5 my-5">
        <h2 class="fw-bold">Ready to Accelerate Your Project?</h2>
        <p class="mb-4 opacity-75">Get instant access to premium source code, documentation, and lifetime updates.</p>
        <button class="btn-cta-custom" onclick="window.location.href='#projects'">Buy Now →</button>
      </div>
    </div>
  </main>

  <div id="footer-placeholder"></div>


  <%- include('footer.ejs') %>
